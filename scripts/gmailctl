#!/usr/bin/env python3
"""Gmail API CLI for OpenClaw — email via Google API.

Config: ~/.config/openclaw-email/gmail.json
  {
    "client_id": "your-google-oauth-client-id",
    "client_secret": "your-google-oauth-client-secret",
    "access_token": "...",
    "refresh_token": "..."
  }

First-time setup:
  1. Go to https://console.cloud.google.com
  2. Create a project, enable Gmail API
  3. OAuth consent screen → External, add your Gmail as test user
  4. Credentials → OAuth 2.0 Client ID → Desktop app
  5. Download client_id and client_secret
  6. Run: gmailctl auth
"""
import sys, os, json, urllib.parse, urllib.request, base64, datetime
import webbrowser, http.server, threading, secrets, email as emaillib
from email.mime.text import MIMEText

CONFIG_DIR = os.path.expanduser("~/.config/openclaw-email")
TOKEN_FILE = os.path.join(CONFIG_DIR, "gmail.json")
TOKEN_URL  = "https://oauth2.googleapis.com/token"
AUTH_URL   = "https://accounts.google.com/o/oauth2/v2/auth"
SCOPES     = "https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/gmail.send"
REDIRECT   = "http://localhost:9999/callback"

def load_config():
    if not os.path.exists(TOKEN_FILE):
        print(f"Config not found: {TOKEN_FILE}\nRun: gmailctl auth", file=sys.stderr)
        sys.exit(1)
    with open(TOKEN_FILE) as f:
        return json.load(f)

def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(TOKEN_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    os.chmod(TOKEN_FILE, 0o600)

def refresh_access_token(cfg):
    data = urllib.parse.urlencode({
        "client_id":     cfg["client_id"],
        "client_secret": cfg["client_secret"],
        "refresh_token": cfg["refresh_token"],
        "grant_type":    "refresh_token",
    }).encode()
    req  = urllib.request.Request(TOKEN_URL, data=data, headers={"Content-Type": "application/x-www-form-urlencoded"})
    resp = json.loads(urllib.request.urlopen(req).read())
    cfg["access_token"] = resp["access_token"]
    save_config(cfg)
    return cfg["access_token"]

def gmail(method, path, body=None, base="https://gmail.googleapis.com/gmail/v1"):
    cfg   = load_config()
    token = cfg["access_token"]
    url   = f"{base}{path}"
    data  = json.dumps(body).encode() if body else None
    hdrs  = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}
    req   = urllib.request.Request(url, data=data, headers=hdrs, method=method)
    try:
        resp    = urllib.request.urlopen(req)
        content = resp.read()
        return json.loads(content) if content else {}
    except urllib.error.HTTPError as e:
        if e.code == 401:
            token = refresh_access_token(cfg)
            hdrs["Authorization"] = f"Bearer {token}"
            req     = urllib.request.Request(url, data=data, headers=hdrs, method=method)
            resp    = urllib.request.urlopen(req)
            content = resp.read()
            return json.loads(content) if content else {}
        err = e.read()
        try:
            err = json.loads(err).get("error", {}).get("message", str(e))
        except Exception:
            err = str(e)
        print(f"Error: {err}", file=sys.stderr)
        sys.exit(1)

# ── Auth ──────────────────────────────────────────────────────────────────────

def cmd_auth(args):
    cfg = {}
    if os.path.exists(TOKEN_FILE):
        cfg = load_config()

    client_id     = cfg.get("client_id")     or input("Google OAuth client_id: ").strip()
    client_secret = cfg.get("client_secret") or input("Google OAuth client_secret: ").strip()

    state  = secrets.token_urlsafe(16)
    params = urllib.parse.urlencode({
        "client_id":             client_id,
        "response_type":         "code",
        "redirect_uri":          REDIRECT,
        "scope":                 SCOPES,
        "state":                 state,
        "access_type":           "offline",
        "prompt":                "consent",
    })
    auth_link   = f"{AUTH_URL}?{params}"
    code_holder = {}

    class Handler(http.server.BaseHTTPRequestHandler):
        def log_message(self, *a): pass
        def do_GET(self):
            parsed = urllib.parse.urlparse(self.path)
            qs     = urllib.parse.parse_qs(parsed.query)
            code_holder["code"] = qs.get("code", [None])[0]
            self.send_response(200)
            self.end_headers()
            self.wfile.write(b"Auth complete. You can close this tab.")

    server = http.server.HTTPServer(("127.0.0.1", 9999), Handler)
    t = threading.Thread(target=server.handle_request)
    t.start()

    print(f"\nOpening browser for Google login...\n{auth_link}\n")
    webbrowser.open(auth_link)
    t.join(timeout=120)
    server.server_close()

    code = code_holder.get("code")
    if not code:
        print("No code received.", file=sys.stderr); sys.exit(1)

    data = urllib.parse.urlencode({
        "client_id":     client_id,
        "client_secret": client_secret,
        "code":          code,
        "redirect_uri":  REDIRECT,
        "grant_type":    "authorization_code",
    }).encode()
    req  = urllib.request.Request(TOKEN_URL, data=data, headers={"Content-Type": "application/x-www-form-urlencoded"})
    resp = json.loads(urllib.request.urlopen(req).read())

    cfg.update({
        "client_id":     client_id,
        "client_secret": client_secret,
        "access_token":  resp["access_token"],
        "refresh_token": resp.get("refresh_token", ""),
    })
    save_config(cfg)
    print("Authenticated. Tokens saved to", TOKEN_FILE)

# ── Email ─────────────────────────────────────────────────────────────────────

def cmd_email_list(args):
    folder = "SENT" if args and args[0] == "sent" else "INBOX"
    result = gmail("GET", f"/users/me/messages?maxResults=20&labelIds={folder}")
    msgs   = result.get("messages", [])
    for m in msgs:
        detail = gmail("GET", f"/users/me/messages/{m['id']}?format=metadata&metadataHeaders=From,Subject,Date")
        hdrs   = {h["name"]: h["value"] for h in detail.get("payload", {}).get("headers", [])}
        read   = " " if "UNREAD" not in detail.get("labelIds", []) else "●"
        sender = hdrs.get("From", "?")[:35]
        date   = hdrs.get("Date", "")[:10]
        print(f"{read} [{m['id'][:12]}] {date}  {sender:<35}  {hdrs.get('Subject','(no subject)')}")

def cmd_email_read(args):
    if not args:
        print("Usage: gmailctl email read <message-id>", file=sys.stderr); sys.exit(1)
    detail = gmail("GET", f"/users/me/messages/{args[0]}?format=full")
    hdrs   = {h["name"]: h["value"] for h in detail.get("payload", {}).get("headers", [])}
    print(f"From:    {hdrs.get('From','')}")
    print(f"To:      {hdrs.get('To','')}")
    print(f"Subject: {hdrs.get('Subject','')}")
    print(f"Date:    {hdrs.get('Date','')}")

    def get_body(payload):
        if payload.get("body", {}).get("data"):
            return base64.urlsafe_b64decode(payload["body"]["data"]).decode("utf-8", errors="replace")
        for part in payload.get("parts", []):
            if part.get("mimeType") == "text/plain":
                return base64.urlsafe_b64decode(part["body"]["data"]).decode("utf-8", errors="replace")
        return ""

    print(f"\n{get_body(detail.get('payload', {}))[:3000]}")

def _make_message(to, subject, body, cc=""):
    msg = MIMEText(body)
    msg["to"]      = to
    msg["subject"] = subject
    if cc:
        msg["cc"] = cc
    raw = base64.urlsafe_b64encode(msg.as_bytes()).decode()
    return {"raw": raw}

def cmd_email_send(args):
    import argparse
    p = argparse.ArgumentParser(prog="gmailctl email send")
    p.add_argument("--to",      required=True)
    p.add_argument("--subject", required=True)
    p.add_argument("--body",    required=True)
    p.add_argument("--cc",      default="")
    opts = p.parse_args(args)
    gmail("POST", "/users/me/messages/send", _make_message(opts.to, opts.subject, opts.body, opts.cc))
    print(f"Email sent to {opts.to}")

def cmd_email_draft(args):
    import argparse
    p = argparse.ArgumentParser(prog="gmailctl email draft")
    p.add_argument("--to",      required=True)
    p.add_argument("--subject", required=True)
    p.add_argument("--body",    required=True)
    opts   = p.parse_args(args)
    result = gmail("POST", "/users/me/drafts", {"message": _make_message(opts.to, opts.subject, opts.body)})
    print(f"Draft created: {result.get('id')}")

# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMANDS = {
    ("auth",):             lambda a: cmd_auth(a),
    ("email", "list"):     cmd_email_list,
    ("email", "read"):     cmd_email_read,
    ("email", "send"):     cmd_email_send,
    ("email", "draft"):    cmd_email_draft,
}

if __name__ == "__main__":
    argv = sys.argv[1:]
    if not argv:
        print("Usage: gmailctl <auth|email> <subcommand> [options]")
        sys.exit(1)
    key = ("auth",) if argv[0] == "auth" else tuple(argv[:2])
    fn  = COMMANDS.get(key)
    if not fn:
        print(f"Unknown command: {' '.join(argv[:2])}", file=sys.stderr)
        sys.exit(1)
    fn(argv[1:] if argv[0] == "auth" else argv[2:])
